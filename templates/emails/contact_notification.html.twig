{% extends 'emails/layout.html.twig' %}

{% block title %}[Contact] {{ subject }} — ZenPDF{% endblock %}

{% block body %}
    <div class="badge badge-yellow">✉️ Nouveau message</div>
    <h1>Nouveau message de contact</h1>

    <div class="meta-box">
        <p><span class="meta-label">Nom :</span> {{ name }}</p>
        <p><span class="meta-label">Email :</span> <a href="mailto:{{ email }}">{{ email }}</a></p>
        <p><span class="meta-label">Sujet :</span> {{ subject }}</p>
    </div>

    <p style="white-space: pre-line; background: #f9fafb; border-left: 3px solid #18181b; padding: 12px 16px; border-radius: 0 6px 6px 0; font-size: 14px; color: #374151;">{{ message }}</p>
{% endblock %}

{% block footer_reason %}Notification interne ZenPDF — formulaire de contact.{% endblock %}